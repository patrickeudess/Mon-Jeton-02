rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function member() { return signedIn() && request.auth.uid in resource.data.memberUids; }
    function owner() { return signedIn() && request.auth.uid == resource.data.createdByUid; }

    match /groups/{groupId} {
      allow create: if signedIn()
        && request.resource.data.createdByUid == request.auth.uid
        && request.auth.uid in request.resource.data.memberUids;
      allow read: if member();
      allow update, delete: if owner()
        || (member()
          && request.resource.data.createdByUid == resource.data.createdByUid
          && request.resource.data.memberUids == resource.data.memberUids);
    }

    match /joinRequests/{requestId} {
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.uid
        && request.resource.data.ownerUid == get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.createdByUid
        && request.resource.data.inviteCode == get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.inviteCode;
      allow read: if signedIn() && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.ownerUid);
      allow delete: if signedIn() && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.ownerUid);
    }

    // Le code est la clé de partage. Le document ne contient aucune donnée
    // financière ; il permet uniquement d'envoyer une demande d'adhésion.
    match /invites/{inviteCode} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
    }
  }
}
